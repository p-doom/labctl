#!/usr/bin/env bash
# Bypass with `git push --no-verify`.
set -e

cd "$(git rev-parse --show-toplevel)"

# --all-features turns on `ui`, which rust-embeds ui/dist/. Build it
# if missing so the failure mode is a test, not an opaque embed error.
if [ ! -d ui/dist ]; then
  echo "→ ui/dist/ missing — running npm run build..."
  (cd ui && npm run build)
fi

echo "→ cargo test --all-features"
cargo test --all-features

echo "✓ pre-push checks passed"
